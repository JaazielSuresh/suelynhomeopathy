<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>S.L. Suresh Homeopathy | Private Consultations</title>
    <!-- Tailwind CSS CDN with plugins -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"
    ></script>
    <!-- Google Fonts: Inter for Sans, Playfair Display for Serif -->
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap"
      rel="普及"
    />
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              brand: {
                light: "#f1f5e8", // Lighter shade of #7FA85A
                DEFAULT: "#7FA85A",
                dark: "#6a8d4b",
                text: "#2d3329",
              },
            },
            fontFamily: {
              sans: ["Inter", "sans-serif"],
              serif: ["Playfair Display", "serif"],
            },
            borderRadius: {
              custom: "8px",
            },
          },
        },
      };
    </script>
    <style data-purpose="custom-typography">
      body {
        font-family: "Inter", sans-serif;
        color: #333333;
        background-color: #f8f9ed;
      }
      h1,
      h2,
      .serif-heading {
        font-family: "Playfair Display", serif;
      }
    </style>
    <style data-purpose="layout-refinements">
      .hero-gradient {
        background: linear-gradient(135deg, #f8f9ed 0%, #f1f4e0 100%);
      }
      .cta-card {
        transition: transform 0.3s ease;
      }
      .cta-card:hover {
        transform: translateY(-4px);
      }
    </style>
  </head>
  <body class="text-gray-800 antialiased">
    <!-- BEGIN: Header -->
    <header
      class="border-b border-gray-100 sticky top-0 backdrop-blur-sm z-50 bg-[#F8F9ED]/95"
      data-purpose="main-navigation"
    >
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center py-4 md:py-6">
          <!-- Logo Section -->
          <div class="flex items-center space-x-2" data-purpose="site-branding">
            <div class="flex flex-col">
              <span
                class="text-2xl font-bold text-brand-dark tracking-tight"
                >S.L. Suresh</span
              >
              <span
                class="text-sm font-light tracking-widest uppercase text-gray-500"
                >Homeopathy</span
              >
            </div>
            <!-- Simple Leaf Icon representation from Logo -->
            <svg
              class="w-8 h-8 text-brand"
              fill="currentColor"
              viewbox="0 0 24 24"
            >
              <path
                d="M17,8C8,10 5.9,16.17 3.82,21.34L5.71,22L6.66,19.7C7.14,19.87 7.64,20 8,20C19,20 22,3 22,3C21,5 14,5.25 9,6.25C4,7.25 2,11.5 2,13.5C2,15.5 3.75,17.25 3.75,17.25C7,8 17,8 17,8Z"
              ></path>
            </svg>
          </div>
          <!-- Trust Marks & Contact -->
          <div class="hidden md:flex items-center space-x-8">
            <div
              class="flex items-center space-x-3 border-r border-gray-200 pr-8"
              data-purpose="trust-badge"
            >
              <div class="text-right">
                <p class="text-[10px] uppercase tracking-tighter text-gray-400">
                  Registered member of
                </p>
                <p class="text-xs font-semibold text-blue-900">
                  Society of Homeopaths
                </p>
              </div>
              <!-- Mock Badge Icon -->
              <div
                class="w-8 h-8 bg-blue-900 rounded-full flex items-center justify-center text-white font-serif italic text-xs"
              >
                S
              </div>
            </div>
            <div class="flex items-center text-sm text-gray-600">
              <svg
                class="w-4 h-4 mr-2"
                fill="none"
                stroke="currentColor"
                viewbox="0 0 24 24"
                ><path
                  d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"></path></svg
              >
              <a
                class="hover:text-brand-dark transition-colors"
                href="mailto:lavenderthyme@protonmail.com"
                >lavenderthyme@protonmail.com</a
              >
            </div>
          </div>
          <!-- Mobile Menu Toggle (Simplified) -->
          <div class="md:hidden">
            <button class="text-gray-500 hover:text-brand">
              <svg
                class="w-6 h-6"
                fill="none"
                stroke="currentColor"
                viewbox="0 0 24 24"
                ><path
                  d="M4 6h16M4 12h16m-7 6h7"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"></path></svg
              >
            </button>
          </div>
        </div>
      </div>
    </header>
    <!-- END: Header -->
    <main>
      <!-- BEGIN: Hero Section -->
      <section
        class="hero-gradient overflow-hidden pt-12 pb-20 md:pt-24 md:pb-32"
        data-purpose="hero"
      >
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
            <!-- Introduction Content -->
            <div
              class="lg:col-span-7 space-y-8"
              data-purpose="introduction-text"
            >
              <div
                class="inline-block px-4 py-1.5 bg-brand-light text-brand-dark rounded-full text-sm font-semibold tracking-wide uppercase"
              >
                Welcome to My Practice
              </div>
              <h1
                class="text-5xl md:text-7xl font-serif text-gray-900 leading-tight"
              >
                Hello! <span class="italic text-brand-dark">I'm Sue.</span>
              </h1>
              <p
                class="text-xl md:text-2xl text-gray-600 leading-relaxed font-light"
              >
                I am a homeopath, Graduated from the Contemporary College of
                Homeopathy, Bristol, UK.
              </p>
              <div class="flex items-center space-x-6">
                <div
                  class="relative w-48 h-48 md:w-56 md:h-56 rounded-full overflow-hidden border-8 border-white shadow-xl flex-shrink-0"
                  data-purpose="profile-image"
                >
                  <img
                    alt="Sue - Professional Homeopath"
                    class="w-full h-full object-cover"
                    src="https://lh3.googleusercontent.com/aida-public/AB6AXuDBqZm6n4WLuyBP3LDP0CnLoLLEI1bFK3GJu3qaNgqTXWKeDctljdo8lSEbjLAEWkOKLvT__YQJHpD2gnCtizU2QIGvIW0HgprdLP8KJwCtUtNYzo1xxD2Hw3eE7HUAUVZDbR5RCik3byu-qTDYJx_NsnNW9r-SvU05Vmh_ENgquSEK82Bwiw71rhMdy-3LcHlGyxDqYf-GmBIL2UtN3ShA0NAdXiorvn7XilJsNB14tiuWJXoQt9Vd5xRgB9ngxjPxaMtOY7APAA"
                  />
                </div>
                <div class="hidden md:block">
                  <p class="text-sm text-gray-400 max-w-[200px] italic">
                    "Creating a safe, supportive space for your health journey."
                  </p>
                </div>
              </div>
            </div>
            <!-- CTA Sidebar Card -->
            <div class="lg:col-span-5" data-purpose="action-sidebar">
              <div
                class="bg-white rounded-2xl shadow-2xl p-8 md:p-10 border border-gray-100 cta-card"
              >
                <h2 class="text-2xl md:text-3xl font-serif text-gray-900 mb-4">
                  Request a private consultation <span
                    class="text-brand-dark font-bold">today.</span>
                </h2>
                <p class="text-gray-500 mb-8 leading-relaxed">
                  Take the first step towards holistic wellness with a
                  personalized session tailored to your unique needs.
                </p>
                <div class="space-y-4">
                  <a
                    class="block w-full text-center bg-brand hover:bg-brand-dark text-white font-bold py-4 rounded-custom transition-all shadow-lg shadow-brand/20 active:scale-95"
                    data-purpose="contact-cta"
                    href="#"
                  >
                    Contact Me
                  </a>
                  <div class="grid grid-cols-2 gap-4">
                    <a
                      class="block text-center border-2 border-brand text-brand hover:bg-brand-light font-semibold py-3 rounded-custom transition-colors"
                      data-purpose="faq-cta"
                      href="#"
                    >
                      FAQ's
                    </a>
                    <a
                      class="block text-center border-2 border-brand text-brand hover:bg-brand-light font-semibold py-3 rounded-custom transition-colors"
                      data-purpose="consultation-info-cta"
                      href="#"
                    >
                      Consultations
                    </a>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>
      <!-- END: Hero Section -->
      <!-- BEGIN: Detailed Intro Section -->
      <section class="py-20 bg-[#F8F9ED]" data-purpose="about-details">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
          <div class="flex justify-center mb-8">
            <span class="h-1 w-20 bg-brand/40 rounded-full"></span>
          </div>
          <p class="text-2xl md:text-3xl font-light text-gray-700 leading-snug">
            I offer a <span class="font-semibold text-brand-dark"
              >safe and supportive space</span
            > to explore your health concerns through homeopathy.
          </p>
          <p class="mt-8 text-lg text-gray-500 max-w-2xl mx-auto">
            If you'd like to know more or book a consultation, please don't
            hesitate to get in touch. Every journey begins with a simple
            conversation.
          </p>
          <button
            class="mt-12 group text-brand-dark font-semibold inline-flex items-center space-x-2 hover:underline"
          >
            <span>Read more about my approach</span>
            <svg
              class="w-4 h-4 transition-transform group-hover:translate-y-1"
              fill="none"
              stroke="currentColor"
              viewbox="0 0 24 24"
              ><path
                d="M19 9l-7 7-7-7"
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"></path></svg
            >
          </button>
        </div>
      </section>
      <!-- END: Detailed Intro Section -->
    </main>
    <!-- BEGIN: Footer -->
    <footer
      class="border-t border-gray-100 py-12 bg-[#f1f4e0]"
      data-purpose="footer"
    >
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div
          class="flex flex-col md:flex-row justify-between items-center space-y-6 md:space-y-0"
        >
          <div class="text-sm text-gray-400">
            © 2023 S.L. Suresh Homeopathy. All rights reserved.
          </div>
          <div class="flex space-x-6 text-sm text-gray-500">
            <a class="hover:text-brand" href="#">Privacy Policy</a>
            <a class="hover:text-brand" href="#">Terms of Service</a>
          </div>
          <div class="flex items-center space-x-2 text-brand-dark font-medium">
            <svg
              class="w-5 h-5"
              fill="none"
              stroke="currentColor"
              viewbox="0 0 24 24"
              ><path
                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"></path></svg
            >
            <a href="mailto:lavenderthyme@protonmail.com"
              >lavenderthyme@protonmail.com</a
            >
          </div>
        </div>
      </div>
    </footer>
    <!-- END: Footer -->
  </body>
</html>
